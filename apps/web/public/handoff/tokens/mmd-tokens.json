{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$name": "Estoque Inteligente MMD — Liquid Glass 2030",
  "$version": "0.1.0",
  "$description": "Design tokens for MMD inventory system. Dark-first, caustic-accented, glass-surfaced. All colors in oklch for perceptual uniformity.",

  "color": {
    "bg": {
      "0": { "$value": "oklch(0.12 0.015 250)", "$description": "App background, deepest" },
      "1": { "$value": "oklch(0.16 0.018 250)", "$description": "Secondary surface" },
      "2": { "$value": "oklch(0.20 0.02 250)",  "$description": "Raised panels" }
    },
    "fg": {
      "0": { "$value": "oklch(0.98 0.005 250)", "$description": "Primary text / hi-contrast" },
      "1": { "$value": "oklch(0.85 0.008 250)", "$description": "Body text" },
      "2": { "$value": "oklch(0.65 0.01 250)",  "$description": "Secondary / labels" },
      "3": { "$value": "oklch(0.48 0.012 250)", "$description": "Tertiary / disabled" }
    },
    "accent": {
      "cyan":   { "$value": "oklch(0.75 0.14 210)", "$description": "Primary action, links, focus" },
      "violet": { "$value": "oklch(0.70 0.17 295)", "$description": "Iridescent secondary, hero moments" },
      "amber":  { "$value": "oklch(0.80 0.15 75)",  "$description": "Warning, partial, caution" },
      "green":  { "$value": "oklch(0.80 0.17 150)", "$description": "Success, ready, OK" },
      "red":    { "$value": "oklch(0.70 0.18 25)",  "$description": "Error, missing, critical" }
    },
    "glass": {
      "bg":              { "$value": "rgba(255,255,255,0.05)" },
      "bg-strong":       { "$value": "rgba(255,255,255,0.09)" },
      "border":          { "$value": "rgba(255,255,255,0.10)" },
      "border-strong":   { "$value": "rgba(255,255,255,0.18)" },
      "highlight":       { "$value": "rgba(255,255,255,0.18)", "$description": "Inset top/left to fake thickness" }
    },
    "light-mode-overrides": {
      "$description": "Applied via :root.light — same tokens, inverted",
      "bg-0":  "oklch(0.97 0.005 250)",
      "fg-0":  "oklch(0.15 0.01 250)",
      "glass-bg": "rgba(255,255,255,0.55)",
      "glass-border": "rgba(0,0,0,0.07)"
    }
  },

  "typography": {
    "family": {
      "sans": { "$value": "'Inter Tight', -apple-system, system-ui, sans-serif", "$description": "UI, body, headings" },
      "mono": { "$value": "'JetBrains Mono', ui-monospace, Menlo, monospace", "$description": "Serials, timestamps, data" }
    },
    "scale": {
      "display": { "$value": { "size": 42, "line": 1.1,  "weight": 500, "tracking": -1.0 } },
      "title":   { "$value": { "size": 28, "line": 1.15, "weight": 500, "tracking": -0.6 } },
      "h2":      { "$value": { "size": 22, "line": 1.2,  "weight": 500, "tracking": -0.3 } },
      "h3":      { "$value": { "size": 17, "line": 1.3,  "weight": 500, "tracking": -0.1 } },
      "body":    { "$value": { "size": 14, "line": 1.5,  "weight": 400, "tracking": 0 } },
      "small":   { "$value": { "size": 12, "line": 1.4,  "weight": 400, "tracking": 0 } },
      "mono-label": { "$value": { "size": 10, "line": 1.3, "weight": 500, "tracking": 1.2, "transform": "uppercase" } }
    }
  },

  "radii": {
    "sm": { "$value": "10px", "$description": "Chips, small buttons" },
    "md": { "$value": "16px", "$description": "Cards, inputs" },
    "lg": { "$value": "24px", "$description": "Panels, sheets" },
    "xl": { "$value": "32px", "$description": "Hero surfaces, device mocks" }
  },

  "spacing": {
    "0.5": "2px", "1": "4px", "2": "8px", "3": "12px",
    "4": "16px", "5": "20px", "6": "24px", "8": "32px",
    "10": "40px", "12": "48px", "16": "64px", "20": "80px"
  },

  "blur": {
    "sm": { "$value": "12px" },
    "md": { "$value": "24px", "$description": "Default glass blur" },
    "lg": { "$value": "40px", "$description": "Floating overlays" }
  },

  "shadow": {
    "glass": {
      "$value": "0 2px 6px rgba(0,0,0,0.25), 0 20px 60px rgba(0,0,0,0.35)",
      "$description": "Default card shadow — dark mode"
    },
    "elevated": {
      "$value": "0 4px 12px rgba(0,0,0,0.35), 0 30px 80px rgba(0,0,0,0.45)",
      "$description": "Floating overlays, modals"
    },
    "glow-cyan": { "$value": "0 0 24px color-mix(in oklch, oklch(0.75 0.14 210) 40%, transparent)" },
    "glow-violet": { "$value": "0 0 24px color-mix(in oklch, oklch(0.70 0.17 295) 40%, transparent)" }
  },

  "motion": {
    "instant": { "$value": "80ms cubic-bezier(0.4, 0, 0.2, 1)" },
    "fast":    { "$value": "180ms cubic-bezier(0.4, 0, 0.2, 1)" },
    "default": { "$value": "240ms cubic-bezier(0.4, 0, 0.2, 1)" },
    "slow":    { "$value": "420ms cubic-bezier(0.4, 0, 0.2, 1)", "$description": "Hero transitions" }
  },

  "ring": {
    "$description": "Readiness rings — a core motif. Value = % ready.",
    "size": { "sm": 48, "md": 72, "lg": 120, "xl": 200 },
    "stroke": { "sm": 4, "md": 6, "lg": 10, "xl": 14 },
    "gradient": {
      "missing": ["#ff6b6b", "#ffb75c"],
      "partial": ["#ffb75c", "#7cc4ff"],
      "ready":   ["#6dd18e", "#7cc4ff"]
    }
  },

  "caustic": {
    "$description": "Iridescent orbs that live under glass surfaces",
    "orb-cyan":   { "pos": "top-left",     "hue": 210, "opacity": 0.55, "blur": "60px" },
    "orb-violet": { "pos": "bottom-right", "hue": 295, "opacity": 0.55, "blur": "60px" },
    "orb-green":  { "pos": "center",       "hue": 150, "opacity": 0.35, "blur": "80px", "optional": true }
  }
}
